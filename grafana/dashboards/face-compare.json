{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Face Compare API — Usage & Monitoring",
  "uid": "face-compare-main",
  "tags": ["face-compare", "facepp-replacement"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-12h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "client",
        "label": "Client",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(facecompare_requests_total, client)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request volume (per sec) — two daily bursts should be visible",
      "description": "sum rate of all compare requests; expect spikes around 09:00 and 18:00 (PRD §4).",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(facecompare_requests_total{client=~\"$client\"}[1m]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total requests (range)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(facecompare_requests_total{client=~\"$client\"}[$__range]))",
          "legendFormat": "requests",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency percentiles (p50 / p95 / p99)",
      "description": "p95 target < 1.5s (PRD §2).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(facecompare_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(facecompare_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(facecompare_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate by error code",
      "description": "Per-error-code breakdown for anomaly investigation (PRD §4 secondary flow).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(facecompare_requests_total{outcome!=\"success\", client=~\"$client\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-client request volume",
      "description": "Useful once more than one internal system calls the API (PRD §4).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (client) (rate(facecompare_requests_total{client=~\"$client\"}[5m]))",
          "legendFormat": "{{client}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Confidence score distribution (p10 / p50 / p90)",
      "description": "Confidence trend over time; sudden shifts can signal model or camera changes.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.10, sum(rate(facecompare_confidence_score_bucket{client=~\"$client\"}[5m])) by (le))",
          "legendFormat": "p10",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(facecompare_confidence_score_bucket{client=~\"$client\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(facecompare_confidence_score_bucket{client=~\"$client\"}[5m])) by (le))",
          "legendFormat": "p90",
          "refId": "C"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Confidence score heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "calculate": false },
      "targets": [
        {
          "expr": "sum(rate(facecompare_confidence_score_bucket{client=~\"$client\"}[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    }
  ]
}
