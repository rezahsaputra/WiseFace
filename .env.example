# Copy to `.env` and fill in. `.env` is git-ignored (PRD §9.7).

# --- API credentials (internal callers) ---
# Inline JSON array of {api_key, api_secret, client}. `client` is a metric
# label only — never an employee identifier.
API_CREDENTIALS=[{"api_key":"CHANGE_ME_KEY","api_secret":"CHANGE_ME_SECRET","client":"attendance-system"}]
# Alternatively, point at a mounted JSON file instead of inline:
# API_CREDENTIALS_FILE=/run/secrets/credentials.json

# --- Recognition model (approved backends only: Facenet512 | SFace | Dlib) ---
MODEL_NAME=Facenet512
# Detector backend: opencv (fast/light) | retinaface | mtcnn (more accurate).
DETECTOR_BACKEND=opencv

# --- Calibration (PLACEHOLDER — replace with Milestone 0 outputs) ---
# method: linear (affine) | logistic (S-curve, expected production form)
CALIBRATION_METHOD=linear
CONFIDENCE_SCALE=100.0
CONFIDENCE_OFFSET=0.0
# logistic params (used when CALIBRATION_METHOD=logistic)
LOGISTIC_MIDPOINT=0.5
LOGISTIC_STEEPNESS=10.0
THRESHOLD_1E_3=62.327
THRESHOLD_1E_4=69.101
THRESHOLD_1E_5=73.975

# --- Image fetching ---
IMAGE_DOWNLOAD_TIMEOUT_S=5.0
MAX_IMAGE_BYTES=10485760
# Downscale inputs whose longest side exceeds this (px) before detection — cuts
# CPU on large phone photos with no accuracy loss (face is resized to 160px
# anyway). 0 disables.
MAX_IMAGE_DIM=1024

# --- Concurrency (burst hardening) ---
# Compares run in parallel PER WORKER. Keep at 1: the OpenCV detector is not
# thread-safe and crashes if a worker runs >1 compare at once. Parallelism comes
# from GUNICORN_WORKERS (separate processes), not this.
INFERENCE_CONCURRENCY=1
# Opt-in load-shedding: max compares a worker holds (running+queued) before
# returning CONCURRENCY_LIMIT_EXCEEDED (HTTP 403). 0 = disabled (queue instead).
# Only enable with even load distribution across workers (see config.py note).
MAX_CONCURRENT_REQUESTS=0

# --- Logging ---
LOG_LEVEL=INFO

# --- Grafana admin (change before exposing the dashboard) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
