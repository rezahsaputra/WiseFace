# Copy to `.env` and fill in. `.env` is git-ignored (PRD §9.7).

# --- API credentials (internal callers) ---
# Inline JSON array of {api_key, api_secret, client}. `client` is a metric
# label only — never an employee identifier.
API_CREDENTIALS=[{"api_key":"CHANGE_ME_KEY","api_secret":"CHANGE_ME_SECRET","client":"attendance-system"}]
# Alternatively, point at a mounted JSON file instead of inline:
# API_CREDENTIALS_FILE=/run/secrets/credentials.json

# --- Recognition model (approved backends only: Facenet512 | SFace | Dlib) ---
MODEL_NAME=Facenet512
# Detector backend: opencv (fast/light) | retinaface | mtcnn (more accurate).
DETECTOR_BACKEND=opencv

# --- Calibration (PLACEHOLDER — replace with Milestone 0 outputs) ---
CONFIDENCE_SCALE=100.0
CONFIDENCE_OFFSET=0.0
THRESHOLD_1E_3=62.327
THRESHOLD_1E_4=69.101
THRESHOLD_1E_5=73.975

# --- Image fetching ---
IMAGE_DOWNLOAD_TIMEOUT_S=5.0
MAX_IMAGE_BYTES=10485760

# --- Logging ---
LOG_LEVEL=INFO

# --- Grafana admin (change before exposing the dashboard) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
